// ============================================================
// Prisma Schema — Calculator History (optional Supabase feature)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Stores individual calculator operations for optional history tracking.
/// No authentication is required — sessions are identified by a client-generated UUID.
model Calculation {
  /// Primary key — UUID v4 generated by the database
  id         String   @id @default(uuid()) @db.Uuid

  /// The full expression as entered/evaluated, e.g. "12 + 7 * 3"
  expression String   @db.Text

  /// The computed result stored as a string to preserve precision for large numbers
  result     String   @db.VarChar(64)

  /// Optional anonymous session UUID set by the client (localStorage) to group history
  sessionId  String?  @db.Uuid

  /// UTC timestamp of when the calculation was performed
  createdAt  DateTime @default(now()) @db.Timestamptz

  @@index([sessionId],  name: "idx_calculations_session")
  @@index([createdAt],  name: "idx_calculations_created")
  @@map("calculations")
}